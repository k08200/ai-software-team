# Required: Your Anthropic API key
ANTHROPIC_API_KEY=your_api_key_here

# Optional: Override the model (default: claude-opus-4-6)
# Note: claude-opus-4-7 will be supported when released
ANTHROPIC_MODEL=claude-opus-4-6

# Optional: Extended thinking token budget per agent (default: 8000, min: 1024)
THINKING_BUDGET=8000

# Optional: Max iteration rounds for QA/Security/Review loop (default: 3)
MAX_ROUNDS=3

# Optional: Minimum rounds before allowing early exit (default: 3)
MIN_ROUNDS=3

# Optional: Server port (default: 3001)
PORT=3001

# Optional: Client origin for CORS (default: http://localhost:3000)
CLIENT_ORIGIN=http://localhost:3000
