# =============================================================================
# AI Software Engineering Team — Environment Variables
# =============================================================================
# Copy to server/.env and fill in the required values.
# Lines marked REQUIRED must be set; everything else has a safe default.

# -----------------------------------------------------------------------------
# Anthropic (REQUIRED)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_api_key_here           # REQUIRED

# Override the model (default: claude-opus-4-6)
ANTHROPIC_MODEL=claude-opus-4-6

# Extended thinking token budget per agent (default: 8000, min: 1024)
THINKING_BUDGET=8000

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# Allowed origin for CORS — set to your frontend URL in production
CLIENT_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Pipeline
# -----------------------------------------------------------------------------
MAX_ROUNDS=3
MIN_ROUNDS=3
MAX_CONCURRENT_PIPELINES=3
OUTPUT_TTL_HOURS=24

# -----------------------------------------------------------------------------
# Database (required for multi-user / auth features)
# -----------------------------------------------------------------------------
# Leave empty for single-user file-based mode
DATABASE_URL=postgres://ast:ast_password@localhost:5432/ai_software_team

# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# PostgreSQL (used by docker-compose.enterprise.yml)
POSTGRES_USER=ast
POSTGRES_PASSWORD=ast_password
POSTGRES_DB=ai_software_team
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# REQUIRED in production — generate with: openssl rand -hex 64
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Stripe billing (optional — leave empty to disable billing)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe dashboard
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_PIPELINE_MAX=5
RATE_LIMIT_PIPELINE_WINDOW_MS=900000   # 15 minutes in ms

# -----------------------------------------------------------------------------
# Redis (optional — used for queue persistence in enterprise mode)
# -----------------------------------------------------------------------------
REDIS_URL=redis://:redis_password@localhost:6379
REDIS_PASSWORD=redis_password
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# pgAdmin (optional — enable with: docker-compose --profile admin up)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# -----------------------------------------------------------------------------
# App (docker-compose.enterprise.yml)
# -----------------------------------------------------------------------------
APP_PORT=3001
